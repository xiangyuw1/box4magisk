{
  "log": {
    "disabled": false,
    "level": "info",
    "output": "sing-box.log",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "tag": "cloudflare",
        "type": "https",
        "server": "1.1.1.1",
        "detour": "Proxy"
      },
      {
        "tag": "ali",
        "type": "https",
        "server": "223.6.6.6",
        "detour": "direct"
      },
      {
        "tag": "remote",
        "type": "fakeip",
        "inet4_range": "198.18.0.0/15",
        "inet6_range": "fc00::/18"
      }
    ],
    "rules": [
      {
        "clash_mode": "Direct",
        "server": "ali"
      },
      {
        "rule_set": [
          "alibaba",
          "category-games@cn"
        ],
        "server": "ali"
      },
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "clash_mode": "AllowAds",
            "invert": true
          },
          {
            "rule_set": [
              "AWAvenue-Ads",
              "category-ads-all"
            ]
          }
        ],
        "action": "reject"
      },
      {
        "rule_set": [
          "cn-domain"
        ],
        "server": "ali"
      },
      {
        "query_type": [
          "A",
          "AAAA"
        ],
        "server": "remote"
      }
    ],
    "strategy": "prefer_ipv4"
  },
  "inbounds": [
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "::",
      "listen_port": 7080
    },
    {
      "type": "tproxy",
      "tag": "tproxy-in",
      "listen": "::",
      "listen_port": 1536
    },
    {
      "type": "tun",
      "tag": "tun-in",
      "address": [
        "172.19.0.1/30",
        "fdfe:dcba:9876::1/126"
      ],
      "auto_route": true,
      "strict_route": true,
      "stack": "system",
      "exclude_package": [
        "com.tailscale.ipn",
        "com.tailscale.android"
      ]
    }
  ],
  "outbounds": [
    {
      "tag": "direct",
      "type": "direct"
    },
    {
      "tag": "vless-kr",
      "type": "vless",
      "server": "",
      "server_port": 443,
      "uuid": "",
      "flow": "xtls-rprx-vision",
      "packet_encoding": "xudp",
      "tls": {
        "enabled": true,
        "server_name": "",
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        },
        "reality": {
          "enabled": true,
          "public_key": "",
          "short_id": ""
        }
      }
    },
    {
      "tag": "vless-us",
      "type": "vless",
      "server": "",
      "server_port": 443,
      "uuid": "",
      "flow": "xtls-rprx-vision",
      "packet_encoding": "xudp",
      "tls": {
        "enabled": true,
        "server_name": "",
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        },
        "reality": {
          "enabled": true,
          "public_key": "",
          "short_id": ""
        }
      }
    },
    {
      "tag": "Proxy",
      "type": "selector",
      "outbounds": [
        "vless-kr",
        "vless-us",
        "direct"
      ],
      "default": "vless-kr",
      "interrupt_exist_connections": true
    }
  ],
  "route": {
    "default_domain_resolver": "ali",
    "rule_set": [
      {
        "tag": "openai",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-openai.srs",
        "download_detour": "Proxy",
        "update_interval": "24h"
      },
      {
        "tag": "anthropic",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-anthropic.srs",
        "download_detour": "Proxy",
        "update_interval": "24h"
      },
      {
        "tag": "AWAvenue-Ads",
        "type": "remote",
        "format": "source",
        "url": "https://raw.githubusercontent.com/TG-Twilight/AWAvenue-Ads-Rule/main/Filters/AWAvenue-Ads-Rule-Singbox.json",
        "download_detour": "Proxy",
        "update_interval": "24h"
      },
      {
        "tag": "category-ads-all",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/CHIZI-0618/v2ray-rules-dat/release/singbox_rule_set/geosite-category-ads-all.srs",
        "download_detour": "Proxy",
        "update_interval": "24h"
      },
      {
        "tag": "alibaba",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-alibaba.srs",
        "download_detour": "Proxy",
        "update_interval": "24h"
      },
      {
        "tag": "category-games@cn",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-category-games@cn.srs",
        "download_detour": "Proxy",
        "update_interval": "24h"
      },
      {
        "tag": "geolocation-!cn",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/CHIZI-0618/v2ray-rules-dat/release/singbox_rule_set/geosite-geolocation-!cn.srs",
        "download_detour": "Proxy",
        "update_interval": "24h"
      },
      {
        "tag": "cn-domain",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/CHIZI-0618/v2ray-rules-dat/release/singbox_rule_set/geosite-cn.srs",
        "download_detour": "Proxy",
        "update_interval": "24h"
      },
      {
        "tag": "cn-ip",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geoip/cn.srs",
        "download_detour": "Proxy",
        "update_interval": "10d"
      }
    ],
    "rules": [
      {
        "action": "sniff"
      },
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "port": 53
          },
          {
            "protocol": "dns"
          }
        ],
        "action": "hijack-dns"
      },
      {
        "clash_mode": "Direct",
        "action": "route",
        "outbound": "direct"
      },
      {
        "rule_set": [
          "alibaba",
          "category-games@cn"
        ],
        "action": "route",
        "outbound": "direct"
      },
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "clash_mode": "AllowAds",
            "invert": true
          },
          {
            "rule_set": [
              "AWAvenue-Ads",
              "category-ads-all"
            ]
          }
        ],
        "action": "reject"
      },
      {
        "rule_set": [
          "openai",
          "anthropic"
        ],
        "action": "route",
        "outbound": "vless-us"
      },
      {
        "process_name": [
          "com.transferwise.android",
          "com.infonow.bofa",
          "atws.app"
        ],
        "domain_suffix": [
          "wise.com",
          "transferwise.com",
          "bankofamerica.com",
          "bofa.com",
          "interactivebrokers.com",
          "ibkr.com"
        ],
        "action": "route",
        "outbound": "vless-us"
      },
      {
        "rule_set": [
          "cn-domain"
        ],
        "action": "route",
        "outbound": "direct"
      },
      {
        "rule_set": "cn-ip",
        "action": "route",
        "outbound": "direct"
      },
      {
        "process_name": [
          "tailscale",
          "tailscaled"
        ],
        "action": "route",
        "outbound": "direct"
      },
      {
        "ip_cidr": [
          "100.64.0.0/10",
          "fd7a:115c:a1e0::/48"
        ],
        "action": "route",
        "outbound": "direct"
      },
      {
        "ip_is_private": true,
        "outbound": "direct"
      }
    ],
    "find_process": true,
    "final": "Proxy"
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "store_fakeip": true
    },
    "clash_api": {
      "default_mode": "Rule",
      "external_controller": "127.0.0.1:9090",
      "secret": "singbox",
      "external_ui": "ui"
    }
  }
}